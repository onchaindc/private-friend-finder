# Solana devnet is the default because it is safest for a hackathon demo.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Fill these after deploying the Arcium PSI MXE / Anchor program.
NEXT_PUBLIC_ARCIUM_PROGRAM_ID=
NEXT_PUBLIC_ARCIUM_CLUSTER_OFFSET=
NEXT_PUBLIC_ARCIUM_COMPUTATION_NAME=private_friend_intersection
